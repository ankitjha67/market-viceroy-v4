# Market Viceroy v4 — example environment file.
#
# Copy to `.env` (git-ignored) and fill in real values for local dev:
#   cp .env.example .env
#
# NEVER commit `.env`. NEVER put secrets in code. See docs/SECRETS.md for
# the vault approach and the exchange-key policy (scoped, withdrawal-
# DISABLED, IP-allowlisted) that applies before any live trading.

# --- ClickHouse (time-series: ticks / bars / features) ---
CLICKHOUSE_DB=marketviceroy
CLICKHOUSE_USER=mv
CLICKHOUSE_PASSWORD=change-me-clickhouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_TCP_PORT=9000

# --- PostgreSQL (relational) ---
POSTGRES_DB=marketviceroy
POSTGRES_USER=mv
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Redis (hot state / bus) ---
REDIS_PASSWORD=change-me-redis
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Data-pipe smoke (CCXT -> ClickHouse) ---
# Public market data only; no exchange API key is required for the smoke.
SMOKE_EXCHANGE=binance
SMOKE_SYMBOL=BTC/USDT
SMOKE_TIMEFRAME=1m
SMOKE_LIMIT=100

# --- Command Deck UI / API ---
# The browser origin the API allows via CORS (the Next.js dev server).
MV_UI_ORIGIN=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:8000   # set for the mv-ui app

# --- Dev gates (tests) ---
# MV_RUN_DB=1        # enable the Postgres integration tests
# MV_RUN_SMOKE=1     # enable the live CCXT data-pipe smoke

# --- Experiment tracking (optional; Phase 9) ---
# MLFLOW_TRACKING_URI=sqlite:///mlflow.db   # opt-in; no-op when unset

# --- LLM routing (optional; offline by default) ---
# ANTHROPIC_API_KEY=                          # cloud LLM for hard reasoning

# ===========================================================================
# Market-data / broker API keys — read from env at call time, NEVER hardcoded.
# All MUST be scoped, withdrawal-DISABLED, IP-allowlisted; vault-stored for any
# shared/live use. Placeholders below; fill the ones you use. (docs/SECRETS.md)
# ===========================================================================

# --- US equities (Phase 6) ---
# FINNHUB_API_KEY=                            # US primary
# ALPACA_API_KEY=
# ALPACA_API_SECRET=                          # US fallback

# --- Macro / commodities / options (intelligence) ---
# FRED_API_KEY=                               # FRED — runtime input ONLY, never trained on
# EIA_API_KEY=
# POLYGON_API_KEY=

# --- India equities — Dhan PRIMARY, then Upstox -> Kotak -> Zerodha -> Angel One ---
# DHAN_ACCESS_TOKEN=                          # India primary
# DHAN_CLIENT_ID=
# UPSTOX_ACCESS_TOKEN=                        # fallback 1
# KOTAK_ACCESS_TOKEN=                         # fallback 2
# KOTAK_CONSUMER_KEY=
# ZERODHA_API_KEY=                            # fallback 3 (Kite — internal-use only, no redistribution)
# ZERODHA_ACCESS_TOKEN=
# ANGELONE_API_KEY=                           # fallback 4
# ANGELONE_ACCESS_TOKEN=

# --- Crypto exchanges (CCXT public OHLCV needs no key; trading would) ---
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
