# Market Viceroy v4 — example environment file.
#
# Copy to `.env` (git-ignored) and fill in real values for local dev:
#   cp .env.example .env
#
# NEVER commit `.env`. NEVER put secrets in code. See docs/SECRETS.md for
# the vault approach and the exchange-key policy (scoped, withdrawal-
# DISABLED, IP-allowlisted) that applies before any live trading.

# --- ClickHouse (time-series: ticks / bars / features) ---
CLICKHOUSE_DB=marketviceroy
CLICKHOUSE_USER=mv
CLICKHOUSE_PASSWORD=change-me-clickhouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_TCP_PORT=9000

# --- PostgreSQL (relational) ---
POSTGRES_DB=marketviceroy
POSTGRES_USER=mv
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Redis (hot state / bus) ---
REDIS_PASSWORD=change-me-redis
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Phase-0 smoke (CCXT -> ClickHouse) ---
# Public market data only; no exchange API key is required for the smoke.
SMOKE_EXCHANGE=binance
SMOKE_SYMBOL=BTC/USDT
SMOKE_TIMEFRAME=1m
SMOKE_LIMIT=100

# --- Exchange API keys (NOT needed for Phase 0; documented for later) ---
# When added, these MUST be scoped, withdrawal-DISABLED, and IP-allowlisted.
# They belong in the vault, never here in plaintext for any shared/live use.
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
